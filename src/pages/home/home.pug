+page({ basename: 'home' })
  +section.experience
    h2.title.title--type_h3.experience__title Experience
    ul.experience__list
      each item in data.experience
        li.experience__item
          .experience__info
            h3.title.title--type_h2.experience__title= item.title
            .experience__company-info
              +link({ text: item.company }).experience__company(
                href=item.link
              )
              .experience__period= item.period
              .experience__location= item.location

          ul.experience__duties
            each dutie in item.duties
              li.experience__dutie= dutie

  +section.skills
    h2.title.title--type_h3.skills__title Skills
    ul.skills__groups
      each group in data.skills
        li.skills__group
          h3.skills__group-title= group.title
          ul.skills__group-skills
            each skill in group.skills
              li.skills__item= skill

  +section.stack
    h2.title.title--type_h3.stack__title Stack List
    ul.stack__list
      each item in data.stack
        li.stack__item
          svg
            use(href=`#${item.icon.name}`)
          span.stack__name= item.name

  +section.education
    h2.title.title--type_h3.education__title Education
    .education__content
      .education__university Saint Petersburg State University of Economics, Russia
      .education__details
        .education__type Faculty of Applied Mathematics and Computer&nbsp;Science
        .education__spec Speciality: Information security

  +section.recommendations
    h2.title.title--type_h3.recommendations__title Recommendations
    ul.recommendations__list
      each item in data.recommendations
        li.recommendations__item
          .recommendations__item-recommender-info
            .recommendations__item-recommender-name= item.recommenderName
            .recommendations__item-recommender-post= item.recommenderPost

          .recommendations__item-text= '"' + item.text + '"'
